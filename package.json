{
  "name": "mojidoodle-contracts",
  "version": "0.3.3",
  "description": "MojiDoodle's shared domain contracts: collection-sample schemas, the grading wire protocol, and kana-matching rules",
  "author": {
    "name": "Lexa Baldwin",
    "email": "lexa.40@proton.me",
    "url": "https://github.com/Lexa-B",
    "orcid": "https://orcid.org/0000-0002-3990-2875"
  },
  "repository": "https://github.com/Lexa-B/MojiDoodle-Contracts",
  "bugs": "https://github.com/Lexa-B/MojiDoodle-Contracts/issues",
  "license": "MIT",
  "keywords": [
    "Japanese",
    "kana",
    "handwriting",
    "contracts",
    "types"
  ],
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "prepublishOnly": "npm run typecheck && npm run build && npm run typecheck:tests && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
